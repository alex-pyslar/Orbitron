{
  "Main function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "\t$0",
      "}"
    ],
    "description": "Main function entry point"
  },

  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:i64} {",
      "\t$0",
      "}"
    ],
    "description": "Function definition"
  },

  "Async function": {
    "prefix": "afn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:i64} {",
      "\t$0",
      "}"
    ],
    "description": "Async function definition"
  },

  "Expression-body function": {
    "prefix": "fne",
    "body": [
      "fn ${1:name}(${2:params}) => ${0:expr};"
    ],
    "description": "Single-expression function"
  },

  "Immutable variable": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${0:value};"
    ],
    "description": "Immutable variable declaration"
  },

  "Mutable variable": {
    "prefix": "varm",
    "body": [
      "var mut ${1:name} = ${0:value};"
    ],
    "description": "Mutable variable declaration"
  },

  "Constant": {
    "prefix": "const",
    "body": [
      "const ${1:NAME}: ${2:i64} = ${0:value};"
    ],
    "description": "Compile-time constant"
  },

  "If statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },

  "If-else statement": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "\t${2:// true branch}",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },

  "Unless statement": {
    "prefix": "unless",
    "body": [
      "unless (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "Unless (inverted if) statement"
  },

  "Match statement": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "\t${2:pattern} => { ${3:// body} }",
      "\t_ => { $0 }",
      "}"
    ],
    "description": "Match expression"
  },

  "For range loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:0}..${3:10} {",
      "\t$0",
      "}"
    ],
    "description": "For range loop"
  },

  "For-in loop": {
    "prefix": "forin",
    "body": [
      "for ${1:item} in ${2:collection} {",
      "\t$0",
      "}"
    ],
    "description": "For-each loop over collection"
  },

  "While loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },

  "Do-while loop": {
    "prefix": "dowhile",
    "body": [
      "do {",
      "\t$0",
      "} while (${1:condition});"
    ],
    "description": "Do-while loop"
  },

  "Repeat N times": {
    "prefix": "repeat",
    "body": [
      "repeat ${1:5} {",
      "\t$0",
      "}"
    ],
    "description": "Repeat N times loop"
  },

  "Struct definition": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:public} var ${3:field}: ${4:i64},",
      "}"
    ],
    "description": "Struct definition"
  },

  "Impl block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Name} {",
      "\tpublic fn ${2:method}(self) -> ${3:i64} {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Impl block for struct"
  },

  "Class definition": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "\tprivate var ${2:field}: ${3:i64},",
      "",
      "\tinit(${4:param}: ${3:i64}) {",
      "\t\tself.${2:field} = ${4:param};",
      "\t}",
      "",
      "\tpublic fn ${5:method}(self) -> ${3:i64} => self.${2:field};",
      "}"
    ],
    "description": "Class definition"
  },

  "Trait definition": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "\tfn ${2:method}(self) -> ${3:void};",
      "}"
    ],
    "description": "Trait definition"
  },

  "Trait implementation": {
    "prefix": "implfor",
    "body": [
      "impl ${1:Trait} for ${2:Type} {",
      "\tfn ${3:method}(self) -> ${4:void} {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Trait implementation"
  },

  "Enum definition": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:Variant1},",
      "\t${3:Variant2},",
      "}"
    ],
    "description": "Enum definition"
  },

  "Goroutine": {
    "prefix": "go",
    "body": [
      "go {",
      "\t$0",
      "};"
    ],
    "description": "Goroutine (background task)"
  },

  "Channel + goroutine": {
    "prefix": "chan",
    "body": [
      "var ${1:ch} = chan();",
      "go { ${1:ch} <- ${2:value}; };",
      "var ${3:val} = <-${1:ch};"
    ],
    "description": "Channel with goroutine"
  },

  "Await expression": {
    "prefix": "await",
    "body": [
      "var ${1:result} = await ${0:expr};"
    ],
    "description": "Await async expression"
  },

  "Defer statement": {
    "prefix": "defer",
    "body": [
      "defer ${0:expr};"
    ],
    "description": "Deferred execution (runs on scope exit)"
  },

  "Interpolated string": {
    "prefix": "istr",
    "body": [
      "\\$\"${1:text}{${2:var}}\""
    ],
    "description": "Interpolated string literal"
  },

  "Println": {
    "prefix": "pl",
    "body": [
      "println(${0:expr});"
    ],
    "description": "println statement"
  },

  "Println interpolated": {
    "prefix": "pli",
    "body": [
      "println(\\$\"${1:msg}: {${0:var}}\");"
    ],
    "description": "println with interpolated string"
  },

  "Import stdlib": {
    "prefix": "import",
    "body": [
      "import \"std/${1|math,bits,algo,sys,net,db|}\";"
    ],
    "description": "Import standard library module"
  },

  "Extern C function": {
    "prefix": "extern",
    "body": [
      "extern fn ${1:name}(${2:params}) -> ${3:i64};"
    ],
    "description": "External C function declaration"
  },

  "Pipe expression": {
    "prefix": "pipe",
    "body": [
      "${1:value} |> ${2:fn1} |> ${0:fn2}"
    ],
    "description": "Pipe operator chain"
  },

  "Ternary expression": {
    "prefix": "tern",
    "body": [
      "${1:cond} ? ${2:true_val} : ${0:false_val}"
    ],
    "description": "Ternary operator"
  }
}
